[
  {
    "label": "reconfigure build",
    "command": "cmake -B build -G Ninja -DCMAKE_BUILD_TYPE=Debug",
    "use_new_terminal": false,
    "reveal": "no_focus",
  },
  {
    "label": "build",
    "command": "cmake --build build",
    "use_new_terminal": false,
    "reveal": "no_focus",
  },
  {
    "label": "test",
    "command": "cmake --build build && ctest --test-dir build --output-on-failure",
    "use_new_terminal": false,
    "reveal": "no_focus",
  },
  {
    "label": "reconfigure coverage build",
    "command": "cmake -B build-coverage  -G Ninja -DCMAKE_BUILD_TYPE=Coverage -DENABLE_COVERAGE=ON",
    "use_new_terminal": false,
    "reveal": "no_focus",
  },
  {
    "label": "coverage",
    "command": "cmake --build build-coverage --target coverage",
    "use_new_terminal": false,
    "reveal": "no_focus",
  },
