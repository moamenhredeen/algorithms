#!/bin/sh

# Check formatting on staged C/H files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(c|h)$')

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

echo "Checking formatting..."
echo "$STAGED_FILES" | xargs clang-format --dry-run --Werror 2>&1
if [ $? -ne 0 ]; then
    echo "Format check failed. Run: clang-format -i <files>"
    exit 1
fi
